<ContentPage
    x:Class="MediSenior.Views.LinkSeniorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Połącz seniora">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="22">

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Połącz konto seniora"
                    Style="{StaticResource PageTitleLabel}" />

                <Label
                    Text="Wpisz kod, który senior widzi na swoim ekranie głównym."
                    Style="{StaticResource SubtitleLabel}" />
            </VerticalStackLayout>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Kod seniora"
                        Style="{StaticResource SmallInfoLabel}" />

                    <Frame Style="{StaticResource InputFrame}">
                        <Entry
                            Text="{Binding SeniorCode}"
                            Placeholder="np. A7K92P"
                            FontSize="26"
                            HorizontalTextAlignment="Center" />
                    </Frame>

                    <Button
                        Text="Połącz"
                        Command="{Binding LinkCommand}" />

                </VerticalStackLayout>
            </Frame>

            <Frame
                BackgroundColor="#EFF6FF"
                BorderColor="#BFDBFE"
                CornerRadius="20"
                Padding="18"
                HasShadow="False">
                <Label
                    Text="Po połączeniu konta zobaczysz listę leków seniora oraz status ich przyjęcia."
                    Style="{StaticResource SubtitleLabel}"
                    HorizontalTextAlignment="Center" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>